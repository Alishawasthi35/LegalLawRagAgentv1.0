# ============================================================
#  Nyaya Legal Research Agent — environment variables
#  Copy to .env.local and fill in. Never commit .env.local.
# ============================================================

# ---- Supabase (https://supabase.com/dashboard) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Service role key — server only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---- Google Gemini (https://aistudio.google.com/apikey) ----
GOOGLE_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# ---- Groq fallback (https://console.groq.com/keys) ----
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ---- IndianKanoon API (https://api.indiankanoon.org/) ----
# Apply for the non-commercial ₹10k/month free credit for judicial research
INDIAN_KANOON_TOKEN=ik_...

# ---- Tavily (https://app.tavily.com) ----
# Optional 4th retrieval source for legal commentary, news, doctrinal articles.
# Free tier: 1000 searches/month. Hugely improves answer quality on niche topics.
TAVILY_API_KEY=tvly-...

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Guest mode (TEMPORARY testing flag) ----
# Set to "true" to disable login entirely and treat every visitor as a guest user.
# All data is shared under a hardcoded guest UUID. Re-enable auth later by setting
# this to "false" (or deleting the line) and redeploying.
# WARNING: do NOT leave this on once your site is in any kind of production use.
NEXT_PUBLIC_DISABLE_AUTH=true

# ---- Cron protection ----
CRON_SECRET=generate-a-random-32-char-string
